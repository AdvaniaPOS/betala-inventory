# Miljøvariabler - Kopier til .env og fyll inn verdier

# Django
SECRET_KEY=generer-en-ny-sikker-nøkkel-her
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# CSRF (for produksjon med Cloudflare Tunnel)
# CSRF_TRUSTED_ORIGINS=https://lager.ditt-domene.no

# Database
# SQLite (enkel oppsett - anbefalt for testing)
USE_SQLITE=true

# PostgreSQL (for produksjon)
# USE_SQLITE=false
# DATABASE_URL=postgres://inventory_user:passord@localhost:5432/festival_inventory
# Eller individuelt:
# DB_NAME=festival_inventory
# DB_USER=inventory_user
# DB_PASSWORD=ditt_passord
# DB_HOST=localhost
# DB_PORT=5432

# Betala API
BETALA_API_URL=https://api.betala.no
BETALA_API_KEY=din-api-nøkkel
BETALA_ORGANIZATION_ID=din-org-id

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# Tidsone
TZ=Europe/Oslo
